# ============================================
# TELEGRAM BOT CONFIG
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram user ID (get from @userinfobot)
ALLOWED_USER_IDS=123456789

# ============================================
# OMADA CONTROLLER CONFIG
# ============================================
# Omada Controller URL (e.g., https://your-omada-controller:8043)
OMADA_CONTROLLER_URL=https://your-omada-controller:8043
OMADA_USERNAME=admin
OMADA_PASSWORD=your_omada_password
OMADA_SITE_ID=your_site_id

# ============================================
# FLUTTERWAVE CONFIG
# ============================================
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key

# ============================================
# EMAIL (SMTP) CONFIG
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Your Business Name

# ============================================
# RE-ENGAGEMENT EMAIL CONTENT
# ============================================
WHATSAPP_LINK=https://wa.me/yournumber
TELEGRAM_BOT_LINK=https://t.me/your_bot_name

# ============================================
# DATABASE
# ============================================
DATABASE_PATH=codes_database.db
