# ============================================
# TELEGRAM BOT CONFIG
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram user ID (get from @userinfobot)
ALLOWED_USER_IDS=123456789

# ============================================
# OMADA CLOUD CONFIG
# ============================================
# Your Omada Cloud portal URL (found in your browser when logged in)
OMADA_CONTROLLER_URL=https://euw1-omada-cloud.tplinkcloud.com
# Your TP-Link ID email (used to login to Omada Cloud)
OMADA_USERNAME=your-email@gmail.com
# Your TP-Link ID password
OMADA_PASSWORD=your_password
# Site ID (auto-detected, leave as default)
OMADA_SITE_ID=default

# ============================================
# FLUTTERWAVE CONFIG
# ============================================
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key

# ============================================
# EMAIL (SMTP) CONFIG
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Your Business Name

# ============================================
# RE-ENGAGEMENT EMAIL CONTENT
# ============================================
WHATSAPP_LINK=https://wa.me/yournumber
TELEGRAM_BOT_LINK=https://t.me/your_bot_name

# ============================================
# DATABASE
# ============================================
DATABASE_PATH=codes_database.db
